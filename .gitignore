# LLMOrchestrator .gitignore — CONST-053 compliant (round-275 + round-291 union).
#
# Forbidden-from-version-control classes per constitution submodule
# §11.4.30 / CONST-053. A `.gitignore` line alone is insufficient — no file
# matching these patterns may be CURRENTLY TRACKED.

# === 1. Build artefacts (CONST-053 §1) ===
/bin/
/build/
/dist/
/out/
target/
*.exe
*.dll
*.so
*.dylib
*.a
*.o
*.class
*.pyc
/orchestrator
/runner
cmd/orchestrator/orchestrator

# Test artefacts
*.test
coverage.out
coverage.html
cover.out
*.prof
profile.out

# === 2. Cache files (CONST-053 §2) ===
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
node_modules/
.next/
.cache/
.gradle/
.terraform/
.gopls-cache/

# === 3. Temp files (CONST-053 §3) ===
*.tmp
*.swp
*.swo
*.orig
*.rej
*~
.DS_Store
Thumbs.db

# === 4. Sensitive-data files (CONST-042 + CONST-053 §4) ===
.env
.env.*
*.env
!.env.example
*.pem
*.key
*.crt
id_rsa*
id_ed25519*
.netrc
secrets/
api_keys.sh

# === 5. Generated reports / logs (CONST-053 §5) ===
*.log
htmlcov/
reports/demos/
reports/runtime/

# === 6. OS / IDE personal state (CONST-053 §6) ===
.idea/
.history/
.vscode/
*.iml

# Runner-emitted temp dirs (round-291 — os.MkdirTemp prefix)
llmorch-round*-*
